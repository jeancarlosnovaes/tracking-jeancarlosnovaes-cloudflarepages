# Supabase (Project Settings > API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Meta (Events Manager > seu Pixel > Configurações > Conversions API)
META_PIXEL_ID=
META_ACCESS_TOKEN=
# Preencha só durante testes (Events Manager > Test Events); remova em produção
META_TEST_EVENT_CODE=

# GA4 (Admin > Fluxos de dados > seu fluxo > Measurement Protocol API secrets)
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# Hotmart (Ferramentas > Webhook > sua configuração > Autenticação)
HOTMART_HOTTOK=

# Código do país (sem +) usado para completar telefones que vierem sem ele.
# Padrão: 55 (Brasil). Só mude se seu público não for majoritariamente BR.
DEFAULT_PHONE_COUNTRY_CODE=55
